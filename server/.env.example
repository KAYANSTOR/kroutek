# =============================================================
# نموذج متغيرات البيئة لسيرفر كروتك (server/api_server.js)
# =============================================================
# انسخ هذا الملف إلى server/.env (أو /.env في جذر المشروع) واملأ قيماً
# حقيقية جديدة تماماً. لا تضع القيم الحقيقية هنا أو في أي ملف يُرفع لـ GitHub.
#
# ⚠️ تنبيه مهم:
# القيم القديمة (KayanSoftSuperSecretJWTKey2026Encryption،
# KayanSoftSecurityHMACKey2026Master، owner/KayanKurotek2026!) كانت مكتوبة
# سابقاً كنص صريح داخل الكود العلني على GitHub، وتُعتبر "محروقة" ومكشوفة
# لأي شخص اطّلع على المستودع. لا تُعِد استخدامها إطلاقاً.
#
# ملاحظة: HMAC_SECRET هنا لا يزال يجب أن يطابق نفس القيمة المُدمجة حالياً
# داخل تطبيق الأندرويد (security/SecurityApiService.kt) وإلا ستفشل كل
# عمليات التحقق من التوقيع فوراً. هذه القيمة ستبقى "معروفة نظرياً" (لأنها
# داخل كل نسخة APK مثبّتة) إلى أن يُنفَّذ الإصلاح الجذري لآلية الترخيص
# (القسم 5.4 من docs/RESTRUCTURING_PLAN.md) مع إصدار تحديث جديد للتطبيق.
# لذلك هذا الملف يعالج "الأسرار المكشوفة في كود السيرفر والباب الخلفي"
# فقط، وليس بديلاً عن إصلاح جذر مشكلة الترخيص.

# مفتاح توقيع جلسات الأدمن (JWT). ولّد قيمة عشوائية قوية جديدة، مثال توليد محلي:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# مفتاح HMAC المشترك بين السيرفر وتطبيق الأندرويد للتحقق من توقيع طلبات التفعيل.
# مؤقتاً يجب أن يطابق القيمة الفعلية المستخدمة حالياً في تطبيق الأندرويد
# (انظر الملاحظة أعلاه) إلى حين تنفيذ إصلاح آلية الترخيص الجذري.
HMAC_SECRET=

# بيانات دخول لوحة تحكم الأدمن (Basic Auth + تسجيل الدخول لواجهة JWT).
# استخدم كلمة مرور قوية وفريدة، غيّرها فوراً عن أي قيمة استُخدمت سابقاً.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# منفذ تشغيل السيرفر (اختياري، الافتراضي 3000)
PORT=3000
